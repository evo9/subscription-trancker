# This file feeds docker-compose (env_file) and is injected into the api/queue/scheduler
# containers. Laravel reads these as real env vars; values here win over apps/api/.env.
# Note: APP_KEY is intentionally NOT set here — `php artisan key:generate` writes it to
# apps/api/.env, and we must not inject an empty APP_KEY that would override it.

# App
APP_NAME="Subscription Tracker"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=subscription_tracker
DB_USERNAME=postgres
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Queue / Cache
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# Mail (log-only in dev)
MAIL_MAILER=log
