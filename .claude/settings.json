{
  "enabledMcpjsonServers": [],
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./apps/api/.env)",
      "Read(./apps/web/.env)",
      "Read(./apps/web/.env.local)"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-git.sh",
            "statusMessage": "Checking git guard..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "docker compose ps api --status running -q 2>/dev/null | grep -q . && docker compose exec -T api ./vendor/bin/pint || true",
            "statusMessage": "PHP code style (Pint) fixing..."
          }
        ]
      }
    ]
  }
}
